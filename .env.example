# opengtm configuration
# Copy to .env and fill in your values

# Required: Gemini API key for lead discovery and research
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: CRM sync via Google Apps Script webhook
CRM_WEBHOOK_URL=your_google_apps_script_dopost_url
CRM_WEBHOOK_TOKEN=your_webhook_auth_token

# Optional: Message language (en or de, default: en)
DEFAULT_LANGUAGE=en

# Optional: Max LinkedIn connection requests per day (default: 20)
DEFAULT_DAILY_LIMIT=20
